# Copy this file's contents into Vercel's Environment Variables UI.
# Never commit a real .env file with real keys to GitHub.

# Required for the primary provider:
GEMINI_API_KEY=

# Optional — leave blank until you have them. The router will
# automatically skip any provider whose key is missing.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults are used if blank):
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — restrict CORS to your real GitHub Pages URL once known,
# e.g. https://yourusername.github.io
ALLOWED_ORIGIN=*
